DJANGO_SECRET_KEY=change-me-before-use
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,trueriver.local,triver.example.test
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3080,http://127.0.0.1:3080,http://triver.example.test

# Optional stable Docker Compose project name. Set this for long-running
# installs if the checkout directory name may change.
COMPOSE_PROJECT_NAME=triver

POSTGRES_DB=triver
POSTGRES_USER=triver
POSTGRES_PASSWORD=change-me-before-use
POSTGRES_HOST=triver-db
POSTGRES_PORT=5432

# Valkey uses the Redis protocol, so Celery URLs keep the redis:// scheme.
VALKEY_URL=redis://triver-valkey:6379/0
CELERY_BROKER_URL=redis://triver-valkey:6379/1
CELERY_RESULT_BACKEND=redis://triver-valkey:6379/2
CELERY_VISIBILITY_TIMEOUT=21600
TRIVER_GUNICORN_WORKERS=3
TRIVER_GUNICORN_TIMEOUT=0
TRIVER_CELERY_WORKER_CONCURRENCY=1
TRIVER_CELERY_WORKER_PREFETCH_MULTIPLIER=1
TRIVER_WORKER_NICE=10
TRIVER_WORKER_IONICE_CLASS=2
TRIVER_WORKER_IONICE_LEVEL=7
TRIVER_PLAYBACK_WORKER_CONCURRENCY=1
TRIVER_PLAYBACK_WORKER_NICE=15
TRIVER_PLAYBACK_WORKER_IONICE_CLASS=3
TRIVER_PLAYBACK_WORKER_IONICE_LEVEL=7
TRIVER_DIGEST_BATCH_SIZE=1
TRIVER_DIGEST_PROGRESS_INTERVAL=1
TRIVER_DIGEST_PARALLEL_BATCHES=false
TRIVER_DIGEST_ITEM_SLEEP_SECONDS=0.35
TRIVER_DIGEST_BATCH_SLEEP_SECONDS=0
TRIVER_DIGEST_FULL_CONTENT_HASH=false
TRIVER_DIGEST_CONTENT_HASH_MAX_BYTES=0
TRIVER_DIGEST_HASH_CHUNK_BYTES=262144
TRIVER_DIGEST_HASH_BYTES_PER_SECOND=1048576
TRIVER_SCAN_SLEEP_EVERY=20
TRIVER_SCAN_ITEM_SLEEP_SECONDS=0.02
TRIVER_DEDUP_SCAN_SLEEP_EVERY=25
TRIVER_DEDUP_SCAN_SLEEP_SECONDS=0.05
TRIVER_DEDUP_MAX_CANDIDATES=200

# Optional remote metadata providers. Configure these locally only; they are
# read by the backend when a manual lookup or configured automation runs.
TRIVER_TMDB_ACCESS_TOKEN=
TRIVER_TMDB_API_KEY=
TRIVER_OMDB_API_KEY=
TRIVER_TVDB_API_KEY=
TRIVER_MUSICBRAINZ_CONTACT=

TRIVER_INGEST_ROOT=/srv/triver/trive-In
TRIVER_DIGEST_ROOT=/srv/triver/trive-Up
TRIVER_NORMALIZE_ROOT=/srv/triver/trive-Out
TRIVER_DUMP_ROOT=/srv/triver/trive-dump
# Optional read-only external folders configured by
# scripts/configure-classic-import-sources.sh. Format:
# key=/srv/triver-classic/key;other=/srv/triver-classic/other
TRIVER_CLASSIC_IMPORT_SOURCES=
TRIVER_COMPOSE_EXTRA=
TRIVER_CLAMAV_ENABLED=true
TRIVER_CLAMAV_HOST=triver-clamav
TRIVER_CLAMAV_PORT=3310
TRIVER_CLAMD_STARTUP_TIMEOUT=1800

VITE_TRIVER_PUBLIC_URL=
VITE_TRIVER_HTTP_ENDPOINT=
VITE_TRIVER_PROXY_SERVICE=triver-proxy
VITE_TRIVER_BACKEND_UPSTREAM=triver-backend:3000
VITE_TRIVER_VPN_ENDPOINT=
VITE_TRIVER_VPN_WEB_URL=
VITE_TRIVER_PROXY_VPN_IP=10.44.0.2
VITE_TRIVER_PROXY_ALLOWED_PORTS=80
VITE_TRIVER_VERSION=
VITE_TRIVER_SOURCE_URL=
VITE_TRIVER_SOURCE_REF=

# Host-side storage paths used by docker-compose.yml.
# Change these to existing folders outside the Git checkout when desired.
TRIVER_POSTGRES_HOST_PATH=/srv/trueriver/postgres
TRIVER_VALKEY_HOST_PATH=/srv/trueriver/valkey
TRIVER_CLAMAV_HOST_PATH=/srv/trueriver/clamav
TRIVER_WIREGUARD_HOST_PATH=/srv/trueriver/wireguard
TRIVER_STORAGE_HOST_PATH=/srv/trueriver/storage
TRIVER_ALLOW_CROSS_DEVICE_MOVES=false

TRIVER_PROXY_BIND=127.0.0.1
TRIVER_PROXY_HTTP_PORT=3080

# Optional: expose trueRiver's internal nginx proxy to an existing edge network.
# See docker-compose.local.yml.
TRIVER_PROXY_CONTAINER_NAME=triver-proxy
TRIVER_PUBLIC_NETWORK=edge_network_name

TRIVER_PROXY_VPN_IP=10.44.0.2
TRIVER_VPN_EDGE_IP=10.44.0.3
TRIVER_VPN_UDP_PORT=51820
TRIVER_VPN_WEB_PORT=51821
TRIVER_VPN_INSECURE=true
TRIVER_VPN_DISABLE_IPV6=true
TRIVER_PROXY_ALLOWED_PORTS=80
TRIVER_VPN_EDGE_SUBNET=10.44.0.0/24
