<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="#000000"
  android:keepScreenOn="true">

  <com.trueriver.tvshell.AudioVisualizerView
    android:id="@+id/audio_visualizer_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone" />

  <androidx.media3.ui.PlayerView
    android:id="@+id/player_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    app:show_buffering="when_playing"
    app:use_controller="true" />

  <LinearLayout
    android:id="@+id/player_header_overlay"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="top"
    android:background="#70000000"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
      android:id="@+id/player_title"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textColor="#F3F6F2"
      android:textSize="28sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/player_subtitle"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:textColor="#CCD5D0"
      android:textSize="16sp" />

    <LinearLayout
      android:id="@+id/player_track_control_row"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/player_captions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="8dp"
        android:background="@drawable/player_caption_pill"
        android:clickable="true"
        android:focusable="true"
        android:paddingLeft="12dp"
        android:paddingTop="6dp"
        android:paddingRight="12dp"
        android:paddingBottom="6dp"
        android:textColor="#B7E1C7"
        android:textSize="14sp" />

      <TextView
        android:id="@+id/player_audio_track"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/player_caption_pill"
        android:clickable="true"
        android:focusable="true"
        android:paddingLeft="12dp"
        android:paddingTop="6dp"
        android:paddingRight="12dp"
        android:paddingBottom="6dp"
        android:textColor="#B7E1C7"
        android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/video_seek_control_row"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="10dp"
      android:orientation="horizontal">

      <Button
        android:id="@+id/video_rewind_long_button"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_marginRight="8dp"
        android:background="@drawable/player_caption_pill"
        android:focusable="true"
        android:minWidth="72dp"
        android:text="-60s"
        android:textAllCaps="false"
        android:textColor="#F3F6F2"
        android:textSize="13sp" />

      <Button
        android:id="@+id/video_rewind_short_button"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_marginRight="8dp"
        android:background="@drawable/player_caption_pill"
        android:focusable="true"
        android:minWidth="72dp"
        android:text="-10s"
        android:textAllCaps="false"
        android:textColor="#F3F6F2"
        android:textSize="13sp" />

      <Button
        android:id="@+id/video_forward_short_button"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_marginRight="8dp"
        android:background="@drawable/player_caption_pill"
        android:focusable="true"
        android:minWidth="72dp"
        android:text="+10s"
        android:textAllCaps="false"
        android:textColor="#F3F6F2"
        android:textSize="13sp" />

      <Button
        android:id="@+id/video_forward_long_button"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:background="@drawable/player_caption_pill"
        android:focusable="true"
        android:minWidth="72dp"
        android:text="+60s"
        android:textAllCaps="false"
        android:textColor="#F3F6F2"
        android:textSize="13sp" />
    </LinearLayout>

    <TextView
      android:id="@+id/player_progress"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="10dp"
      android:textColor="#F3F6F2"
      android:textSize="16sp" />

    <TextView
      android:id="@+id/player_next_up"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:textColor="#B7E1C7"
      android:textSize="14sp" />

    <LinearLayout
      android:id="@+id/audio_control_row"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:orientation="horizontal"
      android:visibility="gone">

      <Button
        android:id="@+id/audio_prev_button"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginRight="8dp"
        android:background="@drawable/player_caption_pill"
        android:focusable="true"
        android:minWidth="84dp"
        android:text="Prev"
        android:textAllCaps="false"
        android:textColor="#F3F6F2" />

      <Button
        android:id="@+id/audio_play_button"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginRight="8dp"
        android:background="@drawable/player_caption_pill"
        android:focusable="true"
        android:minWidth="112dp"
        android:text="Pause"
        android:textAllCaps="false"
        android:textColor="#F3F6F2" />

      <Button
        android:id="@+id/audio_next_button"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:background="@drawable/player_caption_pill"
        android:focusable="true"
        android:minWidth="84dp"
        android:text="Next"
        android:textAllCaps="false"
        android:textColor="#F3F6F2" />
    </LinearLayout>

    <TextView
      android:id="@+id/player_transport_hint"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="10dp"
      android:textColor="#CCD5D0"
      android:textSize="13sp" />
  </LinearLayout>

  <TextView
    android:id="@+id/player_status"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="#B0000000"
    android:padding="20dp"
    android:textColor="#F3F6F2"
    android:textSize="18sp"
    android:visibility="gone" />

</FrameLayout>
